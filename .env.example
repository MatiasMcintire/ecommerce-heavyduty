DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=uct_ecommerce
DB_USER=ecommerce_app
DB_PASS=app_password_here
# OBLIGATORIO (SCRUM-2): minimo 32 caracteres aleatorios. La app NO arranca sin esto.
# Generar uno con:  openssl rand -base64 48
JWT_SECRET=change_this_to_a_random_32_char_string
JWT_EXPIRY=7200
APP_ENV=development
# APP_DEBUG (SCRUM-4): true SOLO en local. En produccion dejar en false (o quitarlo: el default seguro es false).
APP_DEBUG=true
APP_URL=http://localhost
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp_password_here
SMTP_FROM=noreply@example.com
